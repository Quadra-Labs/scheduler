{
    "name": "quadra-scheduler",
    "version": "0.1.0",
    "description": "Quadra Scheduler Engine: watches the jobScheduler database and fires when a job's lifetime ends.",
    "license": "Apache-2.0",
    "type": "module",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js"
        }
    },
    "files": [
        "dist",
        "README.md"
    ],
    "scripts": {
        "build": "tsup",
        "dev": "tsx watch src/server.ts",
        "start": "tsx src/server.ts",
        "typecheck": "tsc --noEmit",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "e2e": "tsx test/e2e.ts",
        "test:eval": "tsx test/eval.ts",
        "test:eval-e2e": "tsx test/eval-e2e.ts"
    },
    "keywords": [
        "quadra",
        "scheduler",
        "walrus",
        "sui"
    ],
    "engines": {
        "node": ">=20"
    },
    "dependencies": {
        "@mysten/sui": "^2.17.0",
        "@noble/ed25519": "^2.3.0",
        "express": "^4.21.2",
        "quadra-data": "file:../data",
        "undici": "^7.0.0"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^22.0.0",
        "prettier": "^3.4.0",
        "tsup": "^8.5.0",
        "tsx": "^4.19.0",
        "typescript": "^5.7.0"
    }
}
